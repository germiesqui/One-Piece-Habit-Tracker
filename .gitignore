# ============================================================
# Grand Line Chronicles — .gitignore
# ============================================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js

# ---- Build outputs ----
dist/
dist-ssr/
build/

# ---- Environment variables — NEVER commit these ----
.env
.env.local
.env.*.local
.env.production

# ---- Vite ----
*.local

# ---- TypeScript ----
*.tsbuildinfo

# ---- Editor ----
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Testing ----
coverage/

# ---- Supabase local dev (if you add it later) ----
supabase/.branches
supabase/.temp